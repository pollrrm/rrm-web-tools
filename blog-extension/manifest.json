{
  "manifest_version": 3,
  "name": "RRM Blog Helper",
  "version": "0.1.0",
  "description": "Side-panel helper for prefilling WordPress Classic Editor blog posts on RRM niche sites. Accepts a single .docx via the side panel or per-post Fill buttons in the DOCX Batch → WordPress tool. Independent of the RRM WP Helper (video) extension.",
  "permissions": ["storage", "sidePanel", "tabs"],
  "host_permissions": [
    "https://pollrrm.github.io/*",
    "https://www.rrmathome.com/*",
    "https://rrmathome.com/*",
    "https://www.seniorcaremarketingmax.com/*",
    "https://seniorcaremarketingmax.com/*",
    "https://www.ringringmarketing.com/*",
    "https://ringringmarketing.com/*",
    "https://www.hospicehavenmarketing.com/*",
    "https://hospicehavenmarketing.com/*"
  ],
  "action": {
    "default_title": "RRM Blog Helper — open side panel"
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://pollrrm.github.io/*",
        "file:///*"
      ],
      "js": ["content-tool.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.rrmathome.com/wp-admin/post-new.php*",
        "https://rrmathome.com/wp-admin/post-new.php*",
        "https://www.rrmathome.com/wp-admin/post.php*",
        "https://rrmathome.com/wp-admin/post.php*",
        "https://www.seniorcaremarketingmax.com/wp-admin/post-new.php*",
        "https://seniorcaremarketingmax.com/wp-admin/post-new.php*",
        "https://www.seniorcaremarketingmax.com/wp-admin/post.php*",
        "https://seniorcaremarketingmax.com/wp-admin/post.php*",
        "https://www.ringringmarketing.com/wp-admin/post-new.php*",
        "https://ringringmarketing.com/wp-admin/post-new.php*",
        "https://www.ringringmarketing.com/wp-admin/post.php*",
        "https://ringringmarketing.com/wp-admin/post.php*",
        "https://www.hospicehavenmarketing.com/wp-admin/post-new.php*",
        "https://hospicehavenmarketing.com/wp-admin/post-new.php*",
        "https://www.hospicehavenmarketing.com/wp-admin/post.php*",
        "https://hospicehavenmarketing.com/wp-admin/post.php*"
      ],
      "js": ["content-wp.js"],
      "run_at": "document_idle"
    }
  ]
}
